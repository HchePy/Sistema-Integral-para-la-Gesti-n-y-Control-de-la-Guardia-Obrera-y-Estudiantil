# Configuración básica de Django
SECRET_KEY=django-insecure-uho-system-development-key-2026-v1
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Base de datos (PostgreSQL para Docker, SQLite local como fallback si está comentada)
# Para correr localmente nativo: descomente la siguiente línea y ajuste sus credenciales
DATABASE_URL=postgres://uho_user:uho_password@localhost:5432/uho_db

# Almacenamiento de archivos S3 / MinIO
USE_MINIO=False
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uho-media
MINIO_ENDPOINT=http://localhost:9000

# Parámetros del Token JWT
JWT_ACCESS_LIFETIME_MINS=120
JWT_REFRESH_LIFETIME_DAYS=7

# Configuración de CORS
CORS_ALLOW_ALL_ORIGINS=True
